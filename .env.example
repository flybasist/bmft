# ============================================================================
# BMFT Bot — Конфигурация (.env)
# ============================================================================
# Инструкция:
#   cp .env.example .env
#   Заполни TELEGRAM_BOT_TOKEN и при необходимости измени остальное.
#   Значения по умолчанию рассчитаны на Сценарий 1 (всё в Docker).
# ============================================================================

# ============================================================================
# ОБЯЗАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# ============================================================================

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ============================================================================
# ПОДКЛЮЧЕНИЕ К POSTGRESQL
# ============================================================================
# Раскомментируй нужный сценарий. По умолчанию активен Сценарий 1.
#
# 🐳 Сценарий 1: БД и бот в Docker (рекомендуется)
#   docker-compose -f docker-compose.env.yaml up -d
#   docker-compose -f docker-compose.bot.yaml up -d --build
#
# 💻 Сценарий 2: БД в Docker, бот локально (для отладки)
#   docker-compose -f docker-compose.env.yaml up -d
#   go run ./cmd/bot/
#   Важно: @localhost вместо @postgres (порт 5432 проброшен наружу)
# ────────────────────────────────────────────────────────────────────────────

# Сценарий 1 (docker → docker)
POSTGRES_DSN=postgres://bmft:bmft@postgres:5432/bmft?sslmode=disable

# Сценарий 2 (docker → localhost)
#POSTGRES_DSN=postgres://bmft:bmft@localhost:5432/bmft?sslmode=disable

# ────────────────────────────────────────────────────────────────────────────
# Параметры контейнера PostgreSQL (docker-compose.env.yaml).
# Нужны только если БД поднимается через docker-compose.
# Должны совпадать с user:password@db в POSTGRES_DSN.
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=bmft
POSTGRES_PASSWORD=bmft
POSTGRES_DB=bmft
POSTGRES_PORT=5432

# ============================================================================
# ЛОГИРОВАНИЕ
# ============================================================================

LOG_LEVEL=info                  # debug | info | warn | error
LOGGER_PRETTY=false             # true — человекочитаемый вывод, false — JSON (prod)

# Ротация файлов логов (lumberjack)
LOG_MAX_SIZE_MB=100             # Макс. размер одного файла (MB)
LOG_MAX_BACKUPS=3               # Сколько старых файлов хранить
LOG_MAX_AGE_DAYS=28             # Макс. возраст файла (дни)

# ============================================================================
# БАЗА ДАННЫХ
# ============================================================================

# Автоочистка старых партиций messages и event_log
DB_RETENTION_MONTHS=6           # Сколько месяцев хранить данные

# ============================================================================
# СЕТЬ И ТАЙМАУТЫ
# ============================================================================

POLLING_TIMEOUT=60              # Long Polling timeout (секунды)
SHUTDOWN_TIMEOUT=15s            # Graceful shutdown timeout
METRICS_ADDR=:9090              # Health check: http://host:9090/healthz

# ============================================================================
# СЛОВАРЬ МАТА
# ============================================================================
# По умолчанию используется встроенный словарь (go:embed).
# Можно заменить на внешний файл или отключить.

#PROFANITY_DICT_SOURCE=embedded  # embedded | file | skip
#PROFANITY_DICT_PATH=            # Путь к файлу (только при source=file)

# ============================================================================
# ЧАСОВОЙ ПОЯС
# ============================================================================
# Используется Go-приложением и контейнерами PostgreSQL / Bot.
# Менять только если сервер в другом часовом поясе.

#TZ=Europe/Moscow